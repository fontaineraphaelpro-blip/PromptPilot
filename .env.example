# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Railway PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/railway

# Auth NextAuth (générer: openssl rand -base64 32) — obligatoire en prod
AUTH_SECRET=
# Alias accepté si tu l'avais déjà sur Railway :
# NEXTAUTH_SECRET=
AUTH_URL=http://localhost:3000

# OpenAI — obligatoire pour la génération
OPENAI_API_KEY=
# Modèle Rapide (défaut gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini
# Modèle Détaillé + Expert (défaut gpt-4o — meilleure qualité)
# OPENAI_MODEL_QUALITY=gpt-4o

# Stripe — obligatoire pour les paiements
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Option A (recommandé) : ID Price Stripe → Produits → ton abo → ID du tarif (commence par price_)
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_CREATOR_PRICE_ID=price_...
# Option B : Payment Link Stripe (https://buy.stripe.com/...) — fonctionne aussi
# NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=https://buy.stripe.com/...
# Si tu utilises des Payment Links, ajoute aussi les vrais price_ pour les webhooks :
# STRIPE_PRO_PRICE_ID=price_...
# STRIPE_CREATOR_PRICE_ID=price_...
# Tarifs annuels (optionnel — active le toggle sur /pricing)
# NEXT_PUBLIC_STRIPE_PRO_PRICE_ID_YEARLY=price_...
# NEXT_PUBLIC_STRIPE_CREATOR_PRICE_ID_YEARLY=price_...

# Support & emails (Resend — https://resend.com)
SUPPORT_EMAIL=support@promptpilot.app
# RESEND_API_KEY=re_...
# EMAIL_FROM=PromptPilot <noreply@votredomaine.com>

# Vidéo démo home (optionnel — URL MP4 ou WebM)
# NEXT_PUBLIC_DEMO_VIDEO_URL=https://...

# Analytics & chat (optionnel)
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=promptpilot.app
# NEXT_PUBLIC_CRISP_WEBSITE_ID=

# Monitoring (optionnel — installer @sentry/nextjs si utilisé)
# SENTRY_DSN=
