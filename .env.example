# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Railway PostgreSQL — créé automatiquement si tu lies Postgres au service
# En local : copie DATABASE_URL depuis Railway → Connect
DATABASE_URL=postgresql://user:password@host:5432/railway

# Supabase — AUTH uniquement (pas la base métier)
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs (Products > Prices)
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=
NEXT_PUBLIC_STRIPE_CREATOR_PRICE_ID=
